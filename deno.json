{
  "$schema": "https://raw.githubusercontent.com/denoland/deno/refs/heads/main/cli/schemas/config-file.v1.json",
  "fmt": {
    "proseWrap": "preserve"
  },
  "lint": {
    "plugins": ["jsr:@aireone/deno-lint-curly"]
  },
  "imports": {
    "@anthropic-ai/sdk": "npm:@anthropic-ai/sdk@^0.80.0",
    "@anthropic-ai/sdk/": "npm:/@anthropic-ai/sdk@^0.80.0/",
    "@discordjs/voice": "npm:@discordjs/voice@0.19.2",
    "ollama": "npm:ollama@^0.6.3",
    "@openai/openai": "jsr:@openai/openai@^6.32.0",
    "@snazzah/davey": "npm:@snazzah/davey@^0.1.10",
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@std/dotenv": "jsr:@std/dotenv@^0.225.6",
    "discord.js": "npm:discord.js@^14.25.1",
    "opusscript": "npm:opusscript@0.1.1"
  },
  "tasks": {
    "start": "deno run -A main.ts",
    "test": "deno test -A --parallel",
    "lint": "deno lint && deno fmt --check ",
    "fix": "deno lint --fix && deno fmt",
    "check": "deno check"
  },
  "allowScripts": {}
}
