# ===== Discord =====
# Discord bot トークン（必須）
DISCORD_TOKEN=
# ギルド（サーバー）ID（必須）
GUILD_ID=

# ===== STT (whisper.cpp) =====
# whisper.cpp サーバーの URL
WHISPER_URL=

# ===== TTS (OpenAI 互換 API) =====
# OpenAI 互換 TTS サーバーの URL（例: voicevox-openai-tts）
OPENAI_TTS_URL=
# TTS サーバーの API キー（不要なら空のまま）
OPENAI_TTS_API_KEY=
# TTS モデル名
OPENAI_TTS_MODEL=
# スピーカー識別子（VOICEVOX の場合はスピーカー ID）
OPENAI_TTS_SPEAKER=1
# 再生速度（デフォルト: 1）
OPENAI_TTS_SPEED=1

# ===== LLM (OpenAI 互換 API) =====
# OpenAI 互換 LLM サーバーの URL（例: OpenClaw, Ollama）
OPENAI_LLM_URL=
# LLM サーバーの API キー（不要なら空のまま）
OPENAI_LLM_API_KEY=
# LLM モデル名
OPENAI_LLM_MODEL=
# LLM に渡すシステムプロンプト（未設定ならシステムメッセージなし）
# SYSTEM_PROMPT=これは音声通話での会話だ。応答は短く、口語体で話せ。

# ===== 音声パイプライン =====
# STT に送る最小発話時間（ミリ秒）。これ未満の音声は無視される
MIN_SPEECH_MS=500
# 発話とみなす最小 RMS 振幅。この値未満はノイズとして破棄
SPEECH_RMS=200
# AI の再生を中断する最小 RMS 振幅。speechRms より高く設定する
INTERRUPT_RMS=500

# ===== ログ =====
# ログレベル: DEBUG / INFO / WARN / ERROR
LOG_LEVEL=INFO

# vim:set ft=sh:
