# ===== Discord =====
# Discord bot トークン（必須）
DISCORD_TOKEN=
# ギルド（サーバー）ID（必須）
GUILD_ID=

# ===== STT (whisper.cpp) =====
# whisper.cpp サーバーの URL
WHISPER_URL=

# ===== TTS (OpenAI 互換 API) =====
# OpenAI 互換 TTS サーバーの URL（例: voicevox-openai-tts）
OPENAI_TTS_URL=
# TTS サーバーの API キー（不要なら空のまま）
OPENAI_TTS_API_KEY=
# TTS モデル名
OPENAI_TTS_MODEL=
# スピーカー識別子（VOICEVOX の場合はスピーカー ID）
OPENAI_TTS_SPEAKER=1
# 再生速度（デフォルト: 1）
OPENAI_TTS_SPEED=1

# ===== LLM =====
# LLM バックエンド: "claude"（デフォルト）または "ollama"
# LLM_TYPE=claude

# --- Claude（LLM_TYPE=claude の場合）---
# Claude API キー
# CLAUDE_API_KEY=
# モデル名（デフォルト: claude-haiku-4-5-20251001）
# CLAUDE_MODEL=claude-haiku-4-5-20251001
# レスポンスの最大トークン数（デフォルト: 1024）
# CLAUDE_MAX_TOKENS=1024
# ツール呼び出しの最大ラウンドトリップ数（デフォルト: 5）
# CLAUDE_MAX_TOOL_ROUNDS=5

# --- Ollama（LLM_TYPE=ollama の場合）---
# Ollama サーバー URL（デフォルト: http://localhost:11434）
# OLLAMA_HOST=http://localhost:11434
# モデル名（例: llama3.1, qwen2.5）
# OLLAMA_MODEL=
# ツール呼び出しの最大ラウンドトリップ数（デフォルト: 5）
# OLLAMA_MAX_TOOL_ROUNDS=5

# LLM に渡すシステムプロンプトファイルのパス（デフォルト: config/SYSTEM_PROMPT.md）
# カンマ区切りで複数指定可能。パスには {{KEY}} 形式のテンプレート変数を使用可能。
# 利用可能な変数: {{discord.guild.id}}, {{discord.guild.name}},
#   {{discord.channel.current.id}}, {{discord.channel.current.name}}
# 例: config/SYSTEM_PROMPT.md,config/channels/{{discord.channel.current.name}}.md
# SYSTEM_PROMPT_FILE=config/SYSTEM_PROMPT.md

# ユーザーメッセージのテンプレート（未設定時はメッセージをそのまま渡す）
# 利用可能な変数: {{discord.user.name}}, {{discord.user.id}}, {{message}}
# MESSAGE_TEMPLATE=[{{discord.user.name}} ({{discord.user.id}})] {{message}}

# ===== 音声パイプライン =====
# STT に送る最小発話時間（ミリ秒）。これ未満の音声は無視される
MIN_SPEECH_MS=500
# 発話とみなす最小 RMS 振幅。この値未満はノイズとして破棄
SPEECH_RMS=200
# AI の再生を中断する最小 RMS 振幅。speechRms より高く設定する
INTERRUPT_RMS=500
# VC に誰もいなくなってから自動退出するまでの時間（ミリ秒）。-1 で無効
AUTO_LEAVE_MS=600000
# 連続発話をまとめるデバウンス待機時間（ミリ秒）
SPEECH_DEBOUNCE_MS=500
# 通知トーン（処理中・エラー）の有効/無効（デフォルト: true）
# NOTIFICATION_TONE=true
# VC 自動参加: "false"（デフォルト）/ "true"（全 VC）/ カンマ区切りチャンネル ID
# AUTO_JOIN_VC=false

# ===== ログ =====
# ログレベル: DEBUG / INFO / WARN / ERROR
LOG_LEVEL=INFO

# vim:set ft=sh:
